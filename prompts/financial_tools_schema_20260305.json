  {
    "type": "function",
    "function": {
      "name": "show_line_chart",
      "description": "Show a line chart of balance over time or cash flow (income, spending, net) over time.",
      "parameters": {
        "type": "object",
        "properties": {
          "chart_type": {
            "description": "Type of line chart to show",
            "enum": ["balance", "cash_flow"],
            "type": "string"
          },
          "time_range": {
            "enum": ["this_month", "last_month", "last_30_days", "last_90_days", "this_year", "last_year"],
            "type": "string"
          },
          "by_account": {
            "description": "Show per-account breakdown (balance only)",
            "type": "boolean"
          }
        }
      }
