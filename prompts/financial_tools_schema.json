[
    {
        "name": "show_line_chart",
        "properties": {
            "metric": {
                "description": "What data to show on the line chart.",
                "enum": [
                    "balance",
                    "net_cash_flow",
                    "income",
                    "spending"
                ],
                "title": "LineChartMetric",
                "type": "string"
            },
            "time_range": {
                "enum": [
                    "this_month",
                    "last_month",
                    "last_30_days",
                    "last_90_days",
                    "this_year"
                ],
                "title": "TimeRange",
                "type": "string"
            },
            "title": {
                "description": "Chart title that describes the visualization",
                "title": "Title",
                "type": "string"
            }
        }
    },
